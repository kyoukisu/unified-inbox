# Non-secret routing configuration only. Credentials belong in ./secrets/.
# Set this to the UID that owns ./secrets (usually the output of `id -u`).
APP_UID=1000
TELEGRAM_CHAT_ID=-1000000000000
TELEGRAM_ALLOWED_USER_ID=000000000
TELEGRAM_POLL_TIMEOUT=30
CORE_LOG_LEVEL=INFO
ADAPTER_LOG_LEVEL=INFO
MAX_IMAGE_BYTES=20971520
DELIVERY_MAX_ATTEMPTS=10
DELIVERY_LEASE_SECONDS=300
DELIVERY_RETRY_MAX_SECONDS=300
STEAM_AUTH_MODE=qr
